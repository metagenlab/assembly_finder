
def parse_summary_tb_fna(wildcards):
    checkpoint_output = checkpoints.combine_assembly_tables.get(**wildcards).output[0]
    tb=pd.read_csv(checkpoint_output,delimiter='\t')
    filenames=tb['AssemblyNames']
    expd=expand('assembly_gz/{sample}.fna',sample=filenames)
    return expd

rule merge_fasta:
    input:
        parse_summary_tb_fna
    output:
        'assembly_gz/merged_assemblies.fna'
    shell:
        """
        cat {input} > {output}
        """